<div class="grid gap-3">
  <template x-for="item in items" :key="item.title">
    <div class="glass rounded-2xl px-5 py-4" x-data="{ open: false }">
      <button type="button" class="flex w-full items-center justify-between gap-4 text-left" @click="open = !open">
        <span class="text-sm font-semibold" x-text="item.title"></span>
        <svg class="h-5 w-5 opacity-80 transition" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="mt-3 text-sm text-ink-300" x-show="open" x-transition.opacity x-text="item.body"></div>
    </div>
  </template>
</div>

