<div x-data="{ open: false }" class="inline-block">
  <button type="button" class="{{triggerClass}}" @click="open = true">{{triggerLabel}}</button>

  <div
    class="fixed inset-0 z-50 grid place-items-center bg-black/45 px-4 py-8 backdrop-blur-sm"
    x-show="open"
    x-transition.opacity
    @keydown.escape.window="open = false"
    aria-hidden="true"
  >
    <div
      class="glass w-full max-w-lg rounded-3xl p-6 md:p-8"
      role="dialog"
      aria-modal="true"
      aria-label="{{title}}"
      @click.outside="open = false"
    >
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="text-lg font-extrabold">{{title}}</div>
          <div class="mt-1 text-sm text-ink-300">{{subtitle}}</div>
        </div>
        <button type="button" class="btn-ghost h-10 w-10 !p-0" @click="open = false" aria-label="Close modal">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="mt-6 text-sm text-ink-200">
        {{{bodyHtml}}}
      </div>

      <div class="mt-8 flex flex-wrap justify-end gap-2">
        <button type="button" class="btn-ghost" @click="open = false">{{cancelLabel}}</button>
        <button type="button" class="btn-primary" @click="open = false">{{confirmLabel}}</button>
      </div>
    </div>
  </div>
</div>

